rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /settings/general {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /private_settings/{document} {
      allow read, write: if isAdmin();
    }

    match /users/{uid} {
      allow read, create, update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();

      match /quiz_attempts/{attempt} {
        allow read: if isOwner(uid) || isAdmin();
      }

      match /otp/{document} {
        allow read, write: if false;
      }
    }

    match /prizes/{prizeId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /token_transactions/{transactionId} {
      allow read: if signedIn() &&
        (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    match /scratch_history/{historyId} {
      allow read: if signedIn() &&
        (resource.data.uid == request.auth.uid || isAdmin());
      allow write: if false;
    }

    match /redemptions/{redemptionId} {
      allow read: if signedIn() &&
        (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /quizzes/{quizId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /matches_state/{fixtureId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /pinnacle_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /pinnacle_bet_attempts/{attemptId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /arquibancada_rooms/{fixtureId} {
      allow read, write: if signedIn();

      match /players/{playerId} {
        allow read, write: if signedIn();

        match /votes/{uid} {
          allow read: if isOwner(uid) || isAdmin();
          allow create, update: if isOwner(uid);
        }
      }

      match /messages/{messageId} {
        allow read: if signedIn();
        allow create: if signedIn() &&
          request.resource.data.userId == request.auth.uid;
        allow update, delete: if isAdmin();
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
